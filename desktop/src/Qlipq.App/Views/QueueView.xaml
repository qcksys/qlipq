<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Qlipq.App.Views.QueueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Qlipq.App.ViewModels"
    xmlns:views="using:Qlipq.App.Views">

    <Grid ColumnDefinitions="340,*">

        <!-- Queue sidebar -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*,Auto" Padding="12"
              BorderThickness="0,0,1,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">

            <HyperlinkButton Grid.Row="0" Content="Rescan all folders" HorizontalAlignment="Right"
                             Command="{Binding RescanAllCommand}"
                             Visibility="{Binding HasWatchedFolders, Converter={StaticResource BoolToVisibility}}" />

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,4">
                <Button Content="All" Click="OnTagAll" Padding="8,2" />
                <ItemsControl ItemsSource="{Binding AllTags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Click="OnTagFilter" Padding="8,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <ListView Grid.Row="2" ItemsSource="{Binding VisibleItems}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QueueItemViewModel">
                        <Border Padding="12" CornerRadius="8" BorderThickness="1"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding MetaLine}" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Top"
                                            Background="{Binding Status, Converter={StaticResource StatusToBrush}}">
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="White" />
                                    </Border>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Tags}"
                                              Visibility="{Binding HasTags, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,1" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                                <TextBlock Text="{Binding}" FontSize="11" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <HyperlinkButton Content="Rename" Click="OnRename" Padding="0" />
                                    <HyperlinkButton Content="{Binding DismissLabel}" Click="OnDismiss" Padding="0" />
                                    <HyperlinkButton Content="Delete file" Click="OnDelete" Padding="0"
                                                     Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <HyperlinkButton Grid.Row="3" Content="Add a watched folder →" Margin="0,8,0,0"
                             Command="{Binding ShowSettingsCommand}" />
        </Grid>

        <!-- Editor / placeholder -->
        <Grid Grid.Column="1">
            <views:EditorView DataContext="{Binding Editor}"
                              Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="Select a clip from the queue to start editing."
                       Opacity="0.7" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVisibility}}" />
        </Grid>
    </Grid>
</UserControl>
