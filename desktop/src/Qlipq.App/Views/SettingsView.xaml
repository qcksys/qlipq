<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Qlipq.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel DataContext="{Binding Config}" MaxWidth="720" Spacing="16" Padding="24" HorizontalAlignment="Center">

            <!-- Watched folders -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Watched folders" FontWeight="SemiBold" />
                    <TextBlock Text="New recordings in these folders (and subfolders) are added to the queue." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding WatchedFolders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6" Padding="12,8" CornerRadius="8"
                                      Background="{ThemeResource ControlFillColorDefaultBrush}">
                                    <TextBlock Grid.Column="0" Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                        <HyperlinkButton Content="Reprocess" Padding="0" Click="OnReprocess" />
                                        <HyperlinkButton Content="Remove" Padding="0" Click="OnRemoveFolder" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add folder…" Command="{Binding AddFolderCommand}" />
                        <ItemsControl ItemsSource="{Binding PresetOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Display}" Click="OnAddPreset" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output folder -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Output folder" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Where exported clips are saved" Width="520" />
                        <Button Content="Browse…" Command="{Binding PickOutputCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Output defaults -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Output defaults" FontWeight="SemiBold" />
                    <TextBlock Text="Applied to every export. The editor shows an estimated file size per clip." Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Quality" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding QualityModeKey, Mode=TwoWay}" Width="200">
                                <ComboBoxItem Content="Preset" Tag="preset" />
                                <ComboBoxItem Content="Custom quality (CRF)" Tag="crf" />
                                <ComboBoxItem Content="VBR (quality + max bitrate)" Tag="vbr" />
                                <ComboBoxItem Content="Target bitrate" Tag="bitrate" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowPreset, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Preset" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding QualityPresetKey, Mode=TwoWay}" Width="200">
                                <ComboBoxItem Content="Original — no re-encode" Tag="original" />
                                <ComboBoxItem Content="High" Tag="high" />
                                <ComboBoxItem Content="Balanced" Tag="balanced" />
                                <ComboBoxItem Content="Small" Tag="small" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowCrf, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="CRF (0–51, lower is better)" Opacity="0.7" FontSize="12" />
                            <NumberBox Value="{Binding Crf, Mode=TwoWay}" Minimum="0" Maximum="51" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding ShowBitrate, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding BitrateLabel}" Opacity="0.7" FontSize="12" />
                            <NumberBox Value="{Binding VideoBitrateKbps, Mode=TwoWay}" Minimum="100" SmallChange="500" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Encoder speed" Opacity="0.7" FontSize="12" />
                            <ComboBox ItemsSource="{Binding EncoderPresetsList}" SelectedItem="{Binding EncoderPreset, Mode=TwoWay}" Width="160" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Codec" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding VideoCodecKey, Mode=TwoWay}" Width="200">
                                <ComboBoxItem Content="H.264" Tag="libx264" />
                                <ComboBoxItem Content="H.265 (smaller, slower)" Tag="libx265" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Container" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding ContainerKey, Mode=TwoWay}" Width="120">
                                <ComboBoxItem Content="mp4" Tag="mp4" />
                                <ComboBoxItem Content="mkv" Tag="mkv" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <StackPanel>
                            <TextBlock Text="Frame rate" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding FpsKey, Mode=TwoWay}" Width="120">
                                <ComboBoxItem Content="Source" Tag="0" />
                                <ComboBoxItem Content="60" Tag="60" />
                                <ComboBoxItem Content="30" Tag="30" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Resolution" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding MaxHeightKey, Mode=TwoWay}" Width="140">
                                <ComboBoxItem Content="Source" Tag="0" />
                                <ComboBoxItem Content="4K (2160p)" Tag="2160" />
                                <ComboBoxItem Content="1440p" Tag="1440" />
                                <ComboBoxItem Content="1080p" Tag="1080" />
                                <ComboBoxItem Content="720p" Tag="720" />
                            </ComboBox>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Audio bitrate" Opacity="0.7" FontSize="12" />
                            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding AudioBitrateKey, Mode=TwoWay}" Width="140">
                                <ComboBoxItem Content="128 kbps" Tag="128" />
                                <ComboBoxItem Content="192 kbps" Tag="192" />
                                <ComboBoxItem Content="256 kbps" Tag="256" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Naming template -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Naming template" FontWeight="SemiBold" />
                    <TextBox Text="{Binding NamingTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Opacity="0.7" FontSize="12" Text="Tokens: {date} {time} {datetime} {source} {name} {index}" />
                </StackPanel>
            </Border>

            <!-- FFmpeg -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="FFmpeg" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                               Text="QlipQ needs ffmpeg and ffprobe on your PATH (or set full paths below). On Windows: winget install Gyan.FFmpeg, then restart QlipQ." />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel>
                            <TextBlock Text="ffmpeg path" Opacity="0.7" FontSize="12" />
                            <TextBox Text="{Binding FfmpegPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="520" />
                        </StackPanel>
                        <Button Content="Test" VerticalAlignment="Bottom" Command="{Binding TestFfmpegCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding FfmpegTest}" FontSize="12" Visibility="{Binding FfmpegTest, Converter={StaticResource NullToVisibility}}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel>
                            <TextBlock Text="ffprobe path" Opacity="0.7" FontSize="12" />
                            <TextBox Text="{Binding FfprobePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="520" />
                        </StackPanel>
                        <Button Content="Test" VerticalAlignment="Bottom" Command="{Binding TestFfprobeCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding FfprobeTest}" FontSize="12" Visibility="{Binding FfprobeTest, Converter={StaticResource NullToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- After export -->
            <Border CornerRadius="12" Padding="16" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="10">
                    <TextBlock Text="After export" FontWeight="SemiBold" />
                    <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                               Text="What to do with the original recording after a clip exports successfully." />
                    <StackPanel>
                        <TextBlock Text="Action" Opacity="0.7" FontSize="12" />
                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding AfterActionKey, Mode=TwoWay}" Width="220">
                            <ComboBoxItem Content="Do nothing" Tag="nothing" />
                            <ComboBoxItem Content="Delete" Tag="delete" />
                            <ComboBoxItem Content="Move to folder" Tag="move" />
                            <ComboBoxItem Content="Rename (prefix/suffix)" Tag="rename" />
                            <ComboBoxItem Content="Prompt each time" Tag="prompt" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{Binding ShowMove, Converter={StaticResource BoolToVisibility}}">
                        <TextBox Text="{Binding MoveFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Destination folder" Width="520" />
                        <Button Content="Browse…" Command="{Binding PickMoveFolderCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{Binding ShowRename, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Prefix" Opacity="0.7" FontSize="12" />
                            <TextBox Text="{Binding RenamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. done-" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Suffix" Opacity="0.7" FontSize="12" />
                            <TextBox Text="{Binding RenameSuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. -archived" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12" DataContext="{Binding}">
                <Button Content="Open config file" Click="OnOpenConfig" />
                <TextBlock Text="Settings save automatically." Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
