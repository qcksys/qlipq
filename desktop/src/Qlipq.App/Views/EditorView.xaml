<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Qlipq.App.Views.EditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Qlipq.App.ViewModels"
    xmlns:lvs="using:LibVLCSharp.Platforms.Windows">

    <Grid>
        <!-- Error state -->
        <StackPanel Padding="24" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Could not read this clip." Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding LoadError}" Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Loading state -->
        <TextBlock Text="Reading clip…" Opacity="0.7" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

        <!-- Editor content -->
        <ScrollViewer Visibility="{Binding Media, Converter={StaticResource NullToVisibility}}">
            <StackPanel Padding="16" Spacing="16">

                <!-- Preview -->
                <Border CornerRadius="12" Background="Black" Height="380">
                    <lvs:VideoView x:Name="Video" Initialized="OnVideoInitialized" />
                </Border>

                <!-- Transport -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <Button Content="−60s" Command="{Binding SkipCommand}" CommandParameter="-60" />
                    <Button Content="−5s" Command="{Binding SkipCommand}" CommandParameter="-5" />
                    <Button Content="−1s" Command="{Binding SkipCommand}" CommandParameter="-1" />
                    <Button Content="Play / Pause" Command="{Binding PlayPauseCommand}" />
                    <Button Content="+1s" Command="{Binding SkipCommand}" CommandParameter="1" />
                    <Button Content="+5s" Command="{Binding SkipCommand}" CommandParameter="5" />
                    <Button Content="+60s" Command="{Binding SkipCommand}" CommandParameter="60" />
                </StackPanel>

                <!-- Timeline -->
                <StackPanel Spacing="8">
                    <Slider x:Name="Scrub" Minimum="0" Maximum="{Binding Duration}" StepFrequency="0.01"
                            Value="{Binding CurrentTime, Mode=OneWay}"
                            ValueChanged="OnScrubChanged" PointerPressed="OnScrubPressed" PointerReleased="OnScrubReleased" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="In" VerticalAlignment="Center" Opacity="0.7" />
                        <NumberBox Value="{Binding TrimStart, Mode=TwoWay}" Minimum="0" Maximum="{Binding Duration}"
                                   SmallChange="0.1" SpinButtonPlacementMode="Compact" Width="120" />
                        <Button Content="Set in at playhead" Command="{Binding SetInAtPlayheadCommand}" />
                        <TextBlock Text="{Binding TrimLengthText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Set out at playhead" Command="{Binding SetOutAtPlayheadCommand}" />
                        <TextBlock Text="Out" VerticalAlignment="Center" Opacity="0.7" />
                        <NumberBox Value="{Binding TrimEnd, Mode=TwoWay}" Minimum="0" Maximum="{Binding Duration}"
                                   SmallChange="0.1" SpinButtonPlacementMode="Compact" Width="120" />
                    </StackPanel>
                </StackPanel>

                <!-- Crop + Audio -->
                <Grid ColumnSpacing="16" ColumnDefinitions="*,*">
                    <Border Grid.Column="0" CornerRadius="12" Padding="16" BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Crop" FontWeight="SemiBold" />
                            <CheckBox IsChecked="{Binding CropEnabled, Mode=TwoWay}">
                                <TextBlock>
                                    <Run Text="Enable crop (" /><Run Text="{Binding SourceDimsText}" /><Run Text=")" />
                                </TextBlock>
                            </CheckBox>
                            <Grid ColumnSpacing="12" RowSpacing="12" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                  Visibility="{Binding CropEnabled, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="X" Opacity="0.7" FontSize="12" />
                                    <NumberBox Value="{Binding CropX, Mode=TwoWay}" Minimum="0" Maximum="{Binding SourceWidth}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="Y" Opacity="0.7" FontSize="12" />
                                    <NumberBox Value="{Binding CropY, Mode=TwoWay}" Minimum="0" Maximum="{Binding SourceHeight}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="Width" Opacity="0.7" FontSize="12" />
                                    <NumberBox Value="{Binding CropWidth, Mode=TwoWay}" Minimum="0" Maximum="{Binding SourceWidth}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBlock Text="Height" Opacity="0.7" FontSize="12" />
                                    <NumberBox Value="{Binding CropHeight, Mode=TwoWay}" Minimum="0" Maximum="{Binding SourceHeight}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="12" Padding="16" BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Audio tracks" FontWeight="SemiBold" />
                            <TextBlock Text="No audio tracks in this clip." Opacity="0.7"
                                       Visibility="{Binding HasAudio, Converter={StaticResource InverseBoolToVisibility}}" />
                            <ItemsControl ItemsSource="{Binding AudioTracks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AudioTrackViewModel">
                                        <StackPanel Spacing="4" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}" MinWidth="0" />
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Detail}" Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="24,0,0,0">
                                                <Slider Minimum="0" Maximum="2" StepFrequency="0.05" Width="180"
                                                        Value="{Binding Volume, Mode=TwoWay}" IsEnabled="{Binding Enabled}" />
                                                <TextBlock Text="{Binding VolumePercent}" Opacity="0.7" FontSize="12" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Quality override -->
                <Border CornerRadius="12" Padding="16" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="12">
                        <CheckBox IsChecked="{Binding OverrideEnabled, Mode=TwoWay}" Content="Override quality for this clip" />
                        <StackPanel Orientation="Horizontal" Spacing="12"
                                    Visibility="{Binding OverrideEnabled, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Quality" Opacity="0.7" FontSize="12" />
                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding OverrideQualityModeKey, Mode=TwoWay}" Width="200">
                                    <ComboBoxItem Content="Preset" Tag="preset" />
                                    <ComboBoxItem Content="Custom quality (CRF)" Tag="crf" />
                                    <ComboBoxItem Content="VBR (quality + max bitrate)" Tag="vbr" />
                                    <ComboBoxItem Content="Target bitrate" Tag="bitrate" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowOverridePreset, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Preset" Opacity="0.7" FontSize="12" />
                                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding OverrideQualityPresetKey, Mode=TwoWay}" Width="200">
                                    <ComboBoxItem Content="Original — no re-encode" Tag="original" />
                                    <ComboBoxItem Content="High" Tag="high" />
                                    <ComboBoxItem Content="Balanced" Tag="balanced" />
                                    <ComboBoxItem Content="Small" Tag="small" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowOverrideCrf, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="CRF (0–51)" Opacity="0.7" FontSize="12" />
                                <NumberBox Value="{Binding OverrideCrf, Mode=TwoWay}" Minimum="0" Maximum="51" />
                            </StackPanel>
                            <StackPanel Visibility="{Binding ShowOverrideBitrate, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding OverrideBitrateLabel}" Opacity="0.7" FontSize="12" />
                                <NumberBox Value="{Binding OverrideVideoBitrateKbps, Mode=TwoWay}" Minimum="100" SmallChange="500" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tags -->
                <Border CornerRadius="12" Padding="16" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Tags" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,2" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                <Button Content="✕" Padding="2,0" FontSize="11" Click="OnRemoveTag" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox PlaceholderText="Add tag…" MinWidth="120"
                                     Text="{Binding NewTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnTagKeyDown" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Export bar -->
                <Border CornerRadius="12" Padding="16" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OutputDurationText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="output ·" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding OutputDimsText}" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="·" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding EstimateText}" Opacity="0.7" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ValidationError}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                       Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibility}}" />
                            <ProgressBar Width="160" Maximum="100" Value="{Binding ProgressPercent}" Margin="8,0,0,0"
                                         VerticalAlignment="Center"
                                         Visibility="{Binding Exporting, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Show file" Margin="0,0,8,0"
                                Command="{Binding ShowExportedFileCommand}"
                                Visibility="{Binding HasExport, Converter={StaticResource BoolToVisibility}}" />
                        <Button Grid.Column="2" Content="{Binding ExportButtonText}" Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{Binding CanExport}" Command="{Binding ExportCommand}" />
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
