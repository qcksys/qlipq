<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Qlipq.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Qlipq.App.Views"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="QlipQ">

    <Grid x:Name="Root" RowDefinitions="Auto,*">

        <!-- Top bar -->
        <Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="Assets/Square44x44Logo.png" Width="22" Height="22" />
                    <TextBlock Text="QlipQ" FontWeight="Bold" VerticalAlignment="Center" />
                    <HyperlinkButton Content="Powered by FFmpeg" FontSize="11"
                                     Command="{Binding OpenFfmpegCommand}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Command="{Binding ShowQueueCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Queue" />
                            <muxc:InfoBadge Value="{Binding PendingCount}" />
                        </StackPanel>
                    </Button>
                    <Button Content="Settings" Command="{Binding ShowSettingsCommand}" />
                    <Button Content="GitHub" Command="{Binding OpenRepoCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <views:QueueView Visibility="{Binding IsQueueView, Converter={StaticResource BoolToVisibility}}" />
            <views:SettingsView Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVisibility}}" />
        </Grid>
    </Grid>
</Window>
