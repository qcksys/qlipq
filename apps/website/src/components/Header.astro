---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const links = [
  { href: `${base}/guide`, label: "Guide" },
  { href: `${base}/guide/obs-replay-buffer`, label: "OBS Setup" },
  { href: `${base}/download`, label: "Download" },
];
---

<header class="site-header">
  <div class="container">
    <a class="logo" href={`${base}/`}>
      <img src={`${base}/favicon.svg`} width="24" height="24" alt="" />
      <span>QlipQ</span>
    </a>
    <nav class="nav">
      {
        links.map((link) => (
          <a href={link.href} aria-current={pathname.startsWith(link.href) ? "page" : undefined}>
            {link.label}
          </a>
        ))
      }
      <a class="btn" href={`${base}/download`}>Get QlipQ</a>
    </nav>
  </div>
</header>
