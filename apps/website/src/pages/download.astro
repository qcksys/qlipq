---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const repo = "https://github.com/qcksys/qlipq";
---

<Base title="Download QlipQ" description="Download QlipQ, a cross-platform clip editor for gameplay capture.">
  <h1>Download QlipQ</h1>
  <p class="lead" style="color:var(--muted)">
    QlipQ is a cross-platform desktop app (Windows, macOS, Linux) built with Rust and
    <a href="https://iced.rs">iced</a>. Build it from source, or grab a prebuilt build from the
    releases page when one is available.
  </p>

  <div class="platforms">
    <div class="card">
      <h3>Windows · macOS · Linux</h3>
      <p>Build the desktop app from source with Cargo — see the
        <a href={`${base}/guide/getting-started`}>getting started</a> guide.</p>
      <p style="margin-top:14px"><a class="btn" href={`${repo}/releases/latest`}>Releases</a></p>
    </div>
  </div>

  <div class="callout">
    <strong>Heads up:</strong> QlipQ's exporter calls <code>ffmpeg</code> and <code>ffprobe</code>.
    Install <a href="https://ffmpeg.org">FFmpeg</a> and make sure it is on your <code>PATH</code>, or
    set the paths in QlipQ's settings.
  </div>

  <p>
    Prefer to build from source? See the <a href={`${base}/guide/getting-started`}>getting started</a>
    guide.
  </p>
</Base>
