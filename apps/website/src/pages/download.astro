---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const repo = "https://github.com/qcksys/qlipq";
---

<Base title="Download QlipQ" description="Download QlipQ for Windows.">
  <h1>Download QlipQ</h1>
  <p class="lead" style="color:var(--muted)">
    QlipQ is a small native Windows desktop app (WinUI 3). <strong>Windows only</strong> — grab the
    latest build from the releases page.
  </p>

  <div class="platforms">
    <div class="card">
      <h3>Windows</h3>
      <p>Windows 10 (1809+) / 11, x64 or Arm64. Signed <code>.msix</code> installer.</p>
      <p style="margin-top:14px"><a class="btn" href={`${repo}/releases/latest`}>Latest release</a></p>
    </div>
  </div>

  <div class="callout">
    <strong>Heads up:</strong> QlipQ is powered by <a href="https://ffmpeg.org">FFmpeg</a> — it calls
    <code>ffmpeg</code> and <code>ffprobe</code>. Install FFmpeg and make sure it is on your
    <code>PATH</code>, or set the paths in QlipQ's settings.
  </div>

  <p>
    Prefer to build from source? See the <a href={`${base}/guide/getting-started`}>getting started</a>
    guide.
  </p>
</Base>
