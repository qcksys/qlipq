---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const guides = (await getCollection("guide")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<Base title="QlipQ user guide">
  <h1>User guide</h1>
  <p class="lead" style="color:var(--muted)">Everything you need to go from recording to clip.</p>
  <ul class="guide-list">
    {
      guides.map((guide) => (
        <li>
          <a href={`${base}/guide/${guide.id}`}>
            <strong>{guide.data.title}</strong>
            <p class="desc">{guide.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
